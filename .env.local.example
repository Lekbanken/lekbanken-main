# ========================================
# SUPABASE CONFIGURATION
# ========================================
# For LOCAL development with `supabase start`:
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase status>

# This is the service role key - NEVER expose in browser
# Only use in server-side code (API routes, middleware)
SUPABASE_SERVICE_ROLE_KEY=<from supabase status>
#
# For PRODUCTION (Vercel sets these per scope):
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ========================================
# ENVIRONMENT & SAFETY
# ========================================
# APP_ENV identifies the data environment (production, staging, local).
# DEPLOY_TARGET identifies the deployment type (prod, preview, development, enterprise-<customer>).
# Both are used for observability tagging and safety guards.
# Vercel sets these per scope — only override locally if needed.
APP_ENV=local
DEPLOY_TARGET=development

# Registration allowlist (comma-separated emails)
# Leave empty to allow all registrations
NEXT_PUBLIC_REGISTRATION_ALLOWLIST=

# ========================================
# AUTHENTICATION & SECURITY
# ========================================
# Add these as environment variables in Vercel dashboard later
# JWT_SECRET=your-jwt-secret-for-middleware
# NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000
TENANT_COOKIE_SECRET=dev-secret-change-in-production
AUTH_TEST_EMAIL=
AUTH_TEST_PASSWORD=

# ========================================
# BILLING & PAYMENTS (Future)
# ========================================
# ========================================
# BILLING & PAYMENTS - STRIPE
# ========================================
# TEST KEYS (Development)
STRIPE_TEST_SECRET_KEY=
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_WEBHOOK_SECRET=

# LIVE KEYS (Production - DO NOT USE IN DEVELOPMENT!)
STRIPE_LIVE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=

# Feature Flags
STRIPE_ENABLED=false
# Set to 'true' to use live keys in development (DANGEROUS!)
STRIPE_USE_LIVE_KEYS=false

# ========================================
# ALTERNATIVE PAYMENT (Future)
# ========================================
# VIPPS_API_KEY=your-vipps-api-key-here
# VIPPS_MERCHANT_SERIAL_NUMBER=your-merchant-number-here

# ========================================
# AI INTEGRATION (Future)
# ========================================
# OPENAI_API_KEY=sk-your-openai-key-here
# NEXT_PUBLIC_AI_MODEL=gpt-4o

# ========================================
# EMAIL SERVICE (Future)
# ========================================
# SENDGRID_API_KEY=SG.your-sendgrid-key-here
# NEXT_PUBLIC_SUPPORT_EMAIL=support@lekbanken.no

# ========================================
# MONITORING & LOGGING
# ========================================
# Errors are logged to Vercel logs and can be viewed in /admin/analytics/errors
# LOG_LEVEL=debug

# ========================================
# DEVELOPMENT TOOLS (Optional)
# ========================================
# DEBUG=true
# NEXT_PUBLIC_DEBUG_MODE=false

# ========================================
# ACHIEVEMENTS ASSETS (Utmärkelser)
# ========================================
# Optional overrides for badge icon asset bases.
# If omitted, the app will use the Supabase public bucket "custom_utmarkelser"
# or fall back to /achievements/utmarkelser/{size}
# NEXT_PUBLIC_ACHIEVEMENTS_ASSET_BASE_SM=https://your-cdn/sm
# NEXT_PUBLIC_ACHIEVEMENTS_ASSET_BASE_MD=https://your-cdn/md
# NEXT_PUBLIC_ACHIEVEMENTS_ASSET_BASE_LG=https://your-cdn/lg
